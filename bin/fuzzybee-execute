#!/usr/bin/env bash
# Fuzzybee CLI wrapper
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON="${PYTHON:-python3}"

case "${1:-}" in
    health)
        PYTHONPATH="$PROJECT_DIR" "$PYTHON" -c "
from lib.engine import ExecutionEngine
e = ExecutionEngine()
h = e.check_health()
print('HEALTHY' if h['engine'] == 'healthy' else 'UNHEALTHY')
for k,v in h.items():
    print(f'  {k}: {v}')
"
        ;;
    decompose)
        problem="${2:-}"
        if [ -z "$problem" ]; then
            echo "Usage: fuzzybee-execute decompose '<problem description>'" >&2
            exit 1
        fi
        PYTHONPATH="$PROJECT_DIR" "$PYTHON" -c "
import sys
from lib.engine import ExecutionEngine
e = ExecutionEngine()
units = e.decompose('$problem')
for u in units:
    print(f'  [{u.unit_type.value}] {u.task_id}: {u.subject}')
    print(f'      pass: {u.pass_criteria}')
"
        ;;
    execute)
        echo "execute: not yet implemented in Phase 1" >&2
        exit 1
        ;;
    verify)
        echo "verify: not yet implemented in Phase 1" >&2
        exit 1
        ;;
    report)
        echo "report: not yet implemented in Phase 1" >&2
        exit 1
        ;;
    *)
        echo "Usage: fuzzybee-execute {health|decompose|execute|verify|report}" >&2
        exit 1
        ;;
esac
